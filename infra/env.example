# ===========================================
# TutorBot Environment Configuration
# ===========================================
# Copy to .env:  cp env.example .env

# Core
ENV=local
BASE_URL=http://localhost:8000

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tutorbot
POSTGRES_USER=tutorbot
POSTGRES_PASSWORD=tutorbot_secret_change_me

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here
TELEGRAM_TMA_BOT_USERNAME=YourBotUsername
TMA_URL=https://t.me/YourBotUsername/app
# Comma-separated Telegram user IDs with no daily limit (e.g. for testing)
# UNLIMITED_TG_IDS=430019680

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_ASSISTANT_ID=asst_your_assistant_id_here
OPENAI_MODEL_VISION=gpt-4o

# Security
JWT_SECRET=your_jwt_secret_change_me_in_production
