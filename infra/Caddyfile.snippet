# TutorBot (GDZ) — Caddy config snippet.
# TMA (port 3000) is the main entry point.
# Its nginx proxies /v1/* and /health to the API (port 8000) internally.
# Add to your main Caddyfile and: sudo systemctl reload caddy

gdz.n8nrgimprovise.space {
    encode gzip
    reverse_proxy localhost:3010
}

# API docs (optional, direct access):
#   http://localhost:8000/docs
#   http://localhost:8000/health
